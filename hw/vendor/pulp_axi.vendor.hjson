{
  name: "pulp_axi",
  target_dir: "pulp_axi",
  patch_dir: "patches/pulp_axi",

  upstream: {
    url: "https://github.com/pulp-platform/axi.git",
    rev: "master",
  },

  exclude_from_upstream: [
    // CI configurations.
    ".ci",
    ".github",
    ".gitlab-ci",
    ".gitlab-ci.yml",
  ]
}
